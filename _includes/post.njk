---
layout: base.njk
---
<div class="post-wrap">
  <header class="post-header section section-dark">
    <div class="container narrow">
      <a class="back-link" href="/blog">&larr; All Posts</a>
      <p class="eyebrow">
        <time datetime="{{ date | isoDate }}">{{ date | dateFilter }}</time>
      </p>
      <h1 class="hero-title accent">{{ title }}</h1>
      {% if description %}
      <p class="post-description">{{ description }}</p>
      {% endif %}
    </div>
  </header>

  <div class="post-body section section-light">
    <div class="container narrow post-content">
      {{ content | safe }}
    </div>
  </div>

  <div class="post-comments section section-dark">
    <div class="container narrow">
      <p class="comments-label">Discussion</p>
      <script src="https://giscus.app/client.js"
              data-repo="rgneufeld/rodneufeld-site"
              data-repo-id="R_kgDOR6ZTrA"
              data-category="Announcements"
              data-category-id="DIC_kwDOR6ZTrM4C64fE"
              data-mapping="pathname"
              data-strict="0"
              data-reactions-enabled="1"
              data-emit-metadata="0"
              data-input-position="bottom"
              data-theme="dark_dimmed"
              data-lang="en"
              crossorigin="anonymous"
              async>
      </script>
    </div>
  </div>
</div>
